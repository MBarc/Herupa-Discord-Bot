# Copy to .env (same folder) and fill in. scripts/setup.sh does this for you.
# NEVER commit the real .env.

# Herupa's Discord bot token (required)
DISCORD_TOKEN=

# Hibiki music worker tokens, comma-separated (blank = music off)
MUSIC_BOT_TOKENS=

# Bitly token (blank = link shortening off)
BITLY_TOKEN=

# Web control room (port 8462): admin password + session-signing secret
HERUPA_WEB_PASSWORD=
HERUPA_WEB_SECRET=

# MongoDB root credentials (must match what the mongo container is
# initialized with; defaults are fine for a LAN-only box)
MONGO_USERNAME=admin
MONGO_PASSWORD=admin

# Timezone for schedules and daily tasks
TZ=America/New_York
